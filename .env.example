# ---- Server ----
PORT=3001
NODE_ENV=development

# ---- Meta WhatsApp Cloud API ----
WHATSAPP_TOKEN=EAAxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=123456789
WHATSAPP_VERIFY_TOKEN=my-custom-verify-token

# ---- Mindbody API ----
MINDBODY_API_KEY=your-api-key
MINDBODY_SITE_ID=-99
MINDBODY_USERNAME=apiuser
MINDBODY_PASSWORD=apipass

# ---- OpenAI ----
OPENAI_API_KEY=sk-proj-xxxxxxxx
OPENAI_MODEL=gpt-4o

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_live_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# ---- Email (SMTP) ----
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=welcome@renessence.com
SMTP_PASS=your-password
ESCALATION_EMAIL=welcome@renessence.com

# ---- Langfuse Observability ----
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ---- Database ----
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ---- Business Info ----
SPA_NAME=Naam van de Spa
SPA_ADDRESS=Straatnaam 123, 1234 AB Amsterdam
SPA_PHONE=+31201234567
SPA_OPENING_HOURS=Ma-Vr 09:00-21:00, Za 10:00-18:00, Zo gesloten
